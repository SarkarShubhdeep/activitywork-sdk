{
  "name": "activitywork-sdk",
  "version": "0.1.0",
  "description": "Typed HTTP client for ActivityWork public APIs (TimeHuddle / server-first)",
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/SarkarShubhdeep/activitywork-sdk.git",
    "directory": "packages/activitywork-sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./preview": {
      "types": "./dist/endpoints/preview.d.ts",
      "import": "./dist/endpoints/preview.js",
      "require": "./dist/endpoints/preview.cjs"
    },
    "./snapshot": {
      "types": "./dist/endpoints/snapshot.d.ts",
      "import": "./dist/endpoints/snapshot.js",
      "require": "./dist/endpoints/snapshot.cjs"
    },
    "./apps": {
      "types": "./dist/endpoints/apps.d.ts",
      "import": "./dist/endpoints/apps.js",
      "require": "./dist/endpoints/apps.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/node": "^22.14.1",
    "eslint": "^9.24.0",
    "globals": "^16.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.1.1"
  }
}
